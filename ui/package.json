{
  "name": "f1-pit-window-ml-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.node.json --noEmit && vite build",
    "preview": "vite preview",
    "prepare:model": "node scripts/generate_manifest.mjs",
    "backend": "cd ../model && PYTHONPATH=. uvicorn f1pit.api.server:app --host 127.0.0.1 --port 8000"
  },
  "dependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.17.10",
    "plotly.js-basic-dist": "^2.35.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-plotly.js": "^2.6.0",
    "three": "^0.166.1"
  },
  "devDependencies": {
    "@types/plotly.js": "^2.12.34",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.166.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.10"
  }
}